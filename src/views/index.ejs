<%- include('partials/header') %>

<section class="hero" x-data="portalApp()" x-init="init()">
  <div class="hero-text">
    <h1>VP Play</h1>
    <p>Cổng giải trí LAN · Tiến Lên Miền Nam · 3 phòng · tối đa 4 người / phòng</p>
  </div>

  <div class="card auth-card" x-show="!profile && !devMode">
    <p>Đăng nhập Keycloak để chơi.</p>
    <button type="button" class="btn primary" @click="login()">Đăng nhập</button>
  </div>

  <div class="card auth-card" x-show="devMode && !profile">
    <p>Chế độ dev (AUTH_DEV_BYPASS): nhập pccuid giả.</p>
    <input type="text" x-model="devId" placeholder="pccuid" />
    <button type="button" class="btn primary" @click="devLogin()">Vào portal</button>
  </div>

  <template x-if="profile">
    <div class="play-area">
      <div class="card">
        <div class="row between">
          <div>
            <strong x-text="profile.displayName"></strong>
            <span class="muted" x-text="'(' + profile.pccuid + ')'"></span>
          </div>
          <button type="button" class="btn ghost" @click="logout()" x-show="!devMode">Đăng xuất</button>
        </div>
      </div>

      <div class="card">
        <h2>Phòng chơi</h2>
        <div class="rooms">
          <template x-for="room in rooms" :key="room.id">
            <div class="room-slot">
              <div class="room-title">Phòng <span x-text="room.id"></span></div>
              <div class="muted" x-text="room.phase + ' · ' + room.seats.length + '/4'"></div>
              <ul class="seat-list">
                <template x-for="s in room.seats" :key="s.pccuid">
                  <li x-text="s.displayName + (s.pccuid === room.hostPccuid ? ' (Host)' : '')"></li>
                </template>
              </ul>
              <button
                type="button"
                class="btn primary"
                @click="joinRoom(room.id)"
                :disabled="room.seats.length >= 4 && !inRoom(room.id)"
              >Vào phòng</button>
            </div>
          </template>
        </div>
      </div>

      <div class="card game-shell" x-show="showGame">
        <div class="row between">
          <h2>Tiến Lên Miền Nam</h2>
          <button type="button" class="btn ghost" @click="closeGame()">Đóng</button>
        </div>
        <iframe
          id="tienlen-frame"
          src="<%= publicPath('/modules/tienlen/index.html') %>?base=<%= encodeURIComponent(appPrefix || '') %>"
          title="Tiến Lên"
          class="game-frame"
          @load="postAuthToGame()"
        ></iframe>
      </div>

      <div class="card" x-show="!showGame">
        <button type="button" class="btn primary" @click="openGame()">Mở bàn Tiến Lên</button>
      </div>
    </div>
  </template>
</section>

<script src="<%= publicPath('/socket.io/socket.io.js') %>"></script>
<script src="<%= publicPath('/js/portal-app.js') %>"></script>

<%- include('partials/footer') %>
