<%- include('partials/header') %>

<section class="page catalog-page" x-data="catalogPage()" x-init="init()">
  <header class="page-header">
    <h1 class="page-title">Ứng dụng</h1>
    <p class="page-sub muted">Cổng giải trí nội bộ · chọn mini-app để chơi</p>
  </header>

  <div class="card auth-card" x-show="authReady && !profile && !devMode">
    <p class="muted" x-show="!authError">Đang xác thực Keycloak…</p>
    <p x-show="authError" x-text="authError"></p>
    <button type="button" class="btn primary" x-show="authError" @click="retryAuth()">Thử lại</button>
  </div>

  <div class="card auth-card" x-show="devMode && !profile">
    <p>Chế độ dev (AUTH_DEV_BYPASS): nhập pccuid giả.</p>
    <p class="muted" x-show="authError" x-text="authError"></p>
    <input type="text" x-model="devId" placeholder="pccuid" />
    <button type="button" class="btn primary" @click="devLogin()">Vào portal</button>
  </div>

  <template x-if="profile">
    <div class="module-grid" role="list">
      <% modules.forEach(function (mod) { %>
      <a
        class="module-tile"
        role="listitem"
        href="<%= publicPath('/apps/' + mod.id) %>"
      >
        <div class="module-tile-icon" data-initials="<%= mod.name.slice(0, 2) %>">
          <img
            src="<%= publicPath(mod.iconPath) %>"
            alt=""
            width="96"
            height="96"
            loading="lazy"
            onerror="this.remove()"
          />
        </div>
        <div class="module-tile-body">
          <h2 class="module-tile-title"><%= mod.name %></h2>
          <p class="module-tile-blurb muted"><%= mod.blurb %></p>
        </div>
      </a>
      <% }) %>
    </div>
  </template>
</section>

<script src="<%= publicPath('/js/portal-catalog.js') %>"></script>

<%- include('partials/footer') %>
