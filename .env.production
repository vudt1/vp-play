# Server
PORT=3000

# Public path as browsers see it (Nginx strips /play → app root)
APP_PREFIX=/play

# SQLite
DATABASE_PATH=./database/play.db

# Keycloak (production)
KEYCLOAK_URL=https://iam.pouchen.com/auth
KEYCLOAK_REALM=pcg
KEYCLOAK_CLIENT_ID=vp-play
KEYCLOAK_ID_CLAIM=pccuid
KEYCLOAK_DISPLAY_NAME_CLAIM=preferred_username

# Game timing (ms)
TURN_TIMEOUT_MS=15000
RECONNECT_MS=60000

# Must be unset or 0 in production
# AUTH_DEV_BYPASS=0
