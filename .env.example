# VP Play environment templates
#
# Copy one of:
#   cp .env.development.example .env.development
#   cp .env.production.example .env.production
#
# Scripts:
#   npm run dev   → loads .env.development (VP_ENV=development)
#   npm start     → loads .env.production  (VP_ENV=production)
#
# Optional fallback: a plain .env is loaded last without overriding keys.
# Do not commit .env, .env.development, or .env.production (secrets).

# --- common variable names ---
# PORT
# APP_PREFIX                 # '' local; /play behind Nginx strip
# DATABASE_PATH
# KEYCLOAK_URL
# KEYCLOAK_REALM
# KEYCLOAK_CLIENT_ID
# KEYCLOAK_ID_CLAIM          # default pccuid
# KEYCLOAK_DISPLAY_NAME_CLAIM # default preferred_username
# TURN_TIMEOUT_MS            # default 30000
# DEAL_GRACE_MS              # default 8000 — pad first turn after deal anim
# RECONNECT_MS
# DRAW_MS                    # default 10000 — Lô tô number draw interval
# KINH_COOLDOWN_MS           # default 30000 — invalid Kinh lockout
# AUTH_DEV_BYPASS            # 1 only for local dev
